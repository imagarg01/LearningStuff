.PHONY: help run-resume run-order

help:
	@echo "Available commands:"
	@echo "  make run-resume   - Run the Resume Extraction demo"
	@echo "  make run-order    - Run the Order Extraction demo"

run-resume:
	@echo "Running Resume Extraction..."
	python3 baml_client_usage.py resume

run-order:
	@echo "Running Order Extraction..."
	python3 baml_client_usage.py order
